#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check if the current project has been initialized with cog-focus
if [ ! -f "cog-focus/config.yaml" ]; then
  exit 0
fi

# Check if reflect/housekeeping are overdue (>7 days or never)
stale_nudges=""

check_staleness() {
  local label="$1" command="$2" key="$3"
  local value
  value=$(grep "^${key}:" cog-focus/config.yaml 2>/dev/null | sed 's/^[^:]*: *//' | tr -d '[:space:]')
  if [ -z "$value" ] || [ "$value" = "never" ]; then
    stale_nudges="${stale_nudges}
- **${label}** has never been run. Suggest the user runs \`/${command}\`."
  else
    # Compare dates — extract YYYY-MM-DD portion
    local last_date="${value:0:10}"
    local now_epoch last_epoch
    now_epoch=$(date +%s)
    last_epoch=$(date -d "$last_date" +%s 2>/dev/null) || last_epoch=0
    local age_days=$(( (now_epoch - last_epoch) / 86400 ))
    if [ "$age_days" -ge 7 ]; then
      stale_nudges="${stale_nudges}
- **${label}** last ran ${age_days} days ago (${last_date}). Suggest the user runs \`/${command}\`."
    fi
  fi
}

check_staleness "Reflect" "reflect" "last_reflect"
check_staleness "Housekeeping" "housekeeping" "last_housekeeping"

# Project has cog-focus enabled — inject instructions
instructions=$(cat "${PLUGIN_ROOT}/hooks/session-instructions.md")
 
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Append staleness nudges if any
if [ -n "$stale_nudges" ]; then
  instructions="${instructions}

## Maintenance Overdue
$stale_nudges"
fi

escaped=$(escape_for_json "$instructions")

# Platform detection - use printf (not heredoc) to avoid bash 5.3+ hang
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi

exit 0
